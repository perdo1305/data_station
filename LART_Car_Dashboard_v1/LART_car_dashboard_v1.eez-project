        },
        {
          "objID": "6409b27d-bce0-4de0-dc39-00614847d276",
          "fileName": "styles.c",
          "template": "#include \"styles.h\"\n#include \"images.h\"\n#include \"fonts.h\"\n\n//${eez-studio LVGL_STYLES_DEF}\n"
        },
        {
          "objID": "d05c0814-03ab-4c21-cef9-684513ff2adc",
          "fileName": "ui.h",
          "template": "#ifndef EEZ_LVGL_UI_GUI_H\n#define EEZ_LVGL_UI_GUI_H\n\n//${eez-studio LVGL_INCLUDE}\n\n//${eez-studio EEZ_FOR_LVGL_CHECK}\n\n#if defined(EEZ_FOR_LVGL)\n#include <eez/flow/lvgl_api.h>\n#endif\n\n#if !defined(EEZ_FOR_LVGL)\n#include \"screens.h\"\n#endif\n\n#ifdef __cplusplus\nextern \"C\" {\n#endif\n\n//${eez-studio GUI_ASSETS_DECL}\n\nvoid ui_init();\nvoid ui_tick();\nvoid ui_set_speed(float speed_kph);\n\n#if !defined(EEZ_FOR_LVGL)\nvoid loadScreen(enum ScreensEnum screenId);\n#endif\n\n#ifdef __cplusplus\n}\n#endif\n\n#endif // EEZ_LVGL_UI_GUI_H"
        },
        {
          "objID": "084926f1-634e-4671-9fc3-cc34c950eba7",
          "fileName": "ui.c",
          "template": "#if defined(EEZ_FOR_LVGL)\n#include <eez/core/vars.h>\n#endif\n\n#include \"ui.h\"\n#include \"screens.h\"\n#include \"images.h\"\n#include \"actions.h\"\n#include \"vars.h\"\n\n#include \"ros2subscriber.h\"\n\n\n//${eez-studio GUI_ASSETS_DEF}\n\n//${eez-studio LVGL_NATIVE_VARS_TABLE_DEF}\n\n//${eez-studio LVGL_ACTIONS_ARRAY_DEF}\n\n#if defined(EEZ_FOR_LVGL)\n\nvoid ui_init() {\n    eez_flow_init(assets, sizeof(assets), (lv_obj_t **)&objects, sizeof(objects), images, sizeof(images), actions);\n    if (ros2subscriber_init() != 0) {\n        ui_set_speed(0.0f);\n        return;\n    }\n\n    ui_set_speed(0.0f);\n}\n\nvoid ui_tick() {\n    float speed_kph;\n\n    if (ros2subscriber_spin_some() == 0 && ros2subscriber_get_latest_speed(&speed_kph)) {\n        ui_set_speed(speed_kph);\n    }\n\n    eez_flow_tick();\n    tick_screen(g_currentScreen);\n}\n\n#else\n\nstatic int16_t currentScreen = -1;\n\nstatic lv_obj_t *getLvglObjectFromIndex(int32_t index) {\n    if (index == -1) {\n        return 0;\n    }\n    return ((lv_obj_t **)&objects)[index];\n}\n\nvoid loadScreen(enum ScreensEnum screenId) {\n    currentScreen = screenId - 1;\n    lv_obj_t *screen = getLvglObjectFromIndex(currentScreen);\n    lv_scr_load_anim(screen, LV_SCR_LOAD_ANIM_FADE_IN, 200, 0, false);\n}\n\nvoid ui_init() {\n    create_screens();\n//${eez-studio LVGL_LOAD_FIRST_SCREEN}\n}\n\nvoid ui_tick() {\n    tick_screen(currentScreen);\n}\n\n#endif\n"
        },
        {
          "objID": "a40698a8-cea3-4c3e-b73f-dca45f315fd8",
          "fileName": "CMakeLists.txt",
          "template": "cmake_minimum_required(VERSION 3.8)\nproject(c_subscriber_example C CXX)\n\nset(CMAKE_CXX_STANDARD 17)\nset(CMAKE_CXX_STANDARD_REQUIRED ON)\n\n# Check if building in ROS 2 environment\nfind_package(ament_cmake QUIET)\n\nif(ament_cmake_FOUND)\n    # Try to find ROS 2 C++ packages (without REQUIRED - they're optional)\n    find_package(rclcpp QUIET)\n    find_package(std_msgs QUIET)\n\n    if(rclcpp_FOUND AND std_msgs_FOUND)\n        # Full ROS 2 build possible\n        message(STATUS \"✓ ROS 2 C++ headers found - enabling ros2subscriber\")\n        add_executable(speed_subscriber ros2subscriber.cpp)\n        ament_target_dependencies(speed_subscriber rclcpp std_msgs)\n\n        install(TARGETS\n          speed_subscriber\n          DESTINATION lib/${PROJECT_NAME})\n\n        ament_package()\n    else()\n        # ament_cmake found but ROS 2 development packages missing\n        message(STATUS \"⚠️  ROS 2 C++ headers not available\")\n        message(STATUS \"    Install with: sudo apt install ros-jazzy-rclcpp ros-jazzy-std-msgs\")\n        message(STATUS \"    Then rebuild: colcon build\")\n        \n        add_executable(speed_subscriber ros2subscriber.cpp)\n        ament_package()\n    endif()\nelse()\n    # Non-ROS 2 build environment (e.g., EEZ Studio)\n    message(STATUS \"⚠️  Building outside ROS 2 ament environment\")\n    message(STATUS \"    ROS 2 C++ headers will not be available\")\n    message(STATUS \"    Enable ROS 2 support by building within colcon:\")\n    message(STATUS \"    $ source /opt/ros/jazzy/setup.bash && colcon build\")\n    \n    add_executable(speed_subscriber ros2subscriber.cpp)\nendif()"
        },
        {
          "objID": "60c1d2cb-d97f-4a4e-dde9-fb14c1587755",
          "fileName": "ros2subscriber.cpp",
          "template": "#include \"ros2subscriber.h\"\n\n#include <stdio.h>\n\n// Keep this file buildable in non-ROS toolchains used by the UI simulator.\n#if defined(__has_include)\n#if __has_include(<rclcpp/rclcpp.hpp>) && __has_include(<std_msgs/msg/float32.hpp>)\n#define LART_HAVE_ROS2_CPP 1\n#define LART_ROS2_CPP_LAYOUT_SHORT 1\n#elif __has_include(<rclcpp/rclcpp/rclcpp.hpp>) && __has_include(<std_msgs/std_msgs/msg/float32.hpp>)\n#define LART_HAVE_ROS2_CPP 1\n#define LART_ROS2_CPP_LAYOUT_NESTED 1\n#endif\n#endif\n\n#if !defined(LART_HAVE_ROS2_CPP)\n#define LART_HAVE_ROS2_CPP 0\n#endif\n\n#if LART_HAVE_ROS2_CPP\n\n#if defined(LART_ROS2_CPP_LAYOUT_NESTED)\n#include <rclcpp/rclcpp/rclcpp.hpp>\n#include <std_msgs/std_msgs/msg/float32.hpp>\n#else\n#include <rclcpp/rclcpp.hpp>\n#include <std_msgs/msg/float32.hpp>\n#endif\n\n#include <exception>\n#include <memory>\n\n#if defined(__GNUC__) || defined(__clang__)\n#define LART_WEAK __attribute__((weak))\n#else\n#define LART_WEAK\n#endif\n\n// Make the exported symbols weak so a stale duplicate object does not break linking.\nnamespace {\nconstexpr const char *TOPIC_NAME = \"/vehicle/speed_kph\";\n\nint g_is_initialized = 0;\nint g_has_speed = 0;\nfloat g_latest_speed_kph = 0.0f;\n\nstd::shared_ptr<rclcpp::Node> g_node;\nrclcpp::Subscription<std_msgs::msg::Float32>::SharedPtr g_subscriber;\nstd::unique_ptr<rclcpp::executors::SingleThreadedExecutor> g_executor;\n}  // namespace\n\nLART_WEAK int ros2subscriber_init(void) {\n    if (g_is_initialized) {\n        return 0;\n    }\n\n    try {\n        if (!rclcpp::ok()) {\n            int argc = 0;\n            char **argv = nullptr;\n            rclcpp::init(argc, argv);\n        }\n\n        g_node = rclcpp::Node::make_shared(\"lart_dashboard_listener\");\n        g_subscriber = g_node->create_subscription<std_msgs::msg::Float32>(\n            TOPIC_NAME,\n            10,\n            [](const std_msgs::msg::Float32 &msg) {\n                g_latest_speed_kph = msg.data;\n                g_has_speed = 1;\n            });\n\n        g_executor = std::make_unique<rclcpp::executors::SingleThreadedExecutor>();\n        g_executor->add_node(g_node);\n    } catch (const std::exception &ex) {\n        fprintf(stderr, \"ros2subscriber init failed: %s\\n\", ex.what());\n        g_subscriber.reset();\n        g_node.reset();\n        g_executor.reset();\n        g_has_speed = 0;\n        return 1;\n    }\n\n    g_is_initialized = 1;\n    return 0;\n}\n\nLART_WEAK int ros2subscriber_spin_some(void) {\n    if (!g_is_initialized || !g_executor) {\n        return 1;\n    }\n\n    try {\n        g_executor->spin_some();\n    } catch (const std::exception &ex) {\n        fprintf(stderr, \"ros2subscriber spin failed: %s\\n\", ex.what());\n        return 1;\n    }\n\n    return 0;\n}\n\nLART_WEAK int ros2subscriber_get_latest_speed(float *speed_kph) {\n    if (!g_is_initialized || !g_has_speed || speed_kph == nullptr) {\n        return 0;\n    }\n\n    *speed_kph = g_latest_speed_kph;\n    return 1;\n}\n\nLART_WEAK void ros2subscriber_fini(void) {\n    if (!g_is_initialized) {\n        return;\n    }\n\n    g_subscriber.reset();\n\n    if (g_executor && g_node) {\n        g_executor->remove_node(g_node);\n    }\n\n    g_executor.reset();\n    g_node.reset();\n\n    if (rclcpp::ok()) {\n        rclcpp::shutdown();\n    }\n\n    g_is_initialized = 0;\n    g_has_speed = 0;\n}\n\n#else\n\nLART_WEAK int ros2subscriber_init(void) {\n    fprintf(stderr, \"ROS 2 C++ headers not available in current include path; ros2subscriber disabled.\\n\");\n    return 1;\n}\n\nLART_WEAK int ros2subscriber_spin_some(void) {\n    return 1;\n}\n\nLART_WEAK int ros2subscriber_get_latest_speed(float *speed_kph) {\n    (void)speed_kph;\n    return 0;\n}\n\nLART_WEAK void ros2subscriber_fini(void) {\n}\n\n#endif\n"
        },
        {
          "objID": "c0ed5029-b756-44df-a764-7ac1293c69f4",
          "fileName": "ros2subscriber.h",
          "template": "#ifndef LART_ROS2SUBSCRIBER_H\n#define LART_ROS2SUBSCRIBER_H\n\n#ifdef __cplusplus\nextern \"C\" {\n#endif\n\nint ros2subscriber_init(void);\nint ros2subscriber_spin_some(void);\nint ros2subscriber_get_latest_speed(float *speed_kph);\nvoid ros2subscriber_fini(void);\n\n#ifdef __cplusplus\n}\n#endif\n\n#endif\n"
        },
        {
          "objID": "f7305de0-3a6b-46e9-9494-4413a6085dd8",
          "fileName": "package.xml",
          "template": "<?xml version=\"1.0\"?>\n<?xml-model href=\"http://download.ros.org/schema/package_format3.xsd\"\n            schematypens=\"http://www.w3.org/2001/XMLSchema\"?>\n<package format=\"3\">\n  <name>c_subscriber_example</name>\n  <version>0.1.0</version>\n  <description>ROS 2 C++ subscriber example used by the dashboard container build</description>\n  <maintainer email=\"lart@example.com\">LART</maintainer>\n  <license>MIT</license>\n\n  <buildtool_depend>ament_cmake</buildtool_depend>\n  <build_depend>rclcpp</build_depend>\n  <build_depend>std_msgs</build_depend>\n\n  <exec_depend>rclcpp</exec_depend>\n  <exec_depend>std_msgs</exec_depend>\n\n  <export>\n    <build_type>ament_cmake</build_type>\n  </export>\n</package>\n"
        }
      ],
